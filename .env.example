# ============================================
# Misty Isle 环境变量配置示例
# 复制此文件为 .env 并修改配置
# ============================================

# 应用环境: development, production
APP_ENV=development

# 服务器端口
SERVER_PORT=8080

# ============================================
# PostgreSQL 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=misty_isle
# 或直接使用 DSN（优先级最高）
# DB_DSN=postgres://postgres:postgres@localhost:5432/misty_isle?sslmode=disable&charset=utf8&TimeZone=Asia/Shanghai

# ============================================
# Redis 配置（用于验证码、重置令牌等）
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE_HOURS=72

# ============================================
# R2 对象存储配置（Cloudflare）
# ============================================
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=videos
R2_PUBLIC_URL=https://cdn.yourdomain.com  # 前端会用这个拼接 HLS 路径

# ============================================
# SRS 流媒体服务器配置
# ============================================
SRS_HTTP_URL=http://localhost:8080
SRS_RTMP_URL=rtmp://localhost:1935

# 公网地址
SRS_PUBLIC_RTMP_URL=rtmp://localhost:1935
SRS_PUBLIC_HTTP_URL=http://localhost:8080

# ============================================
# SMTP 邮件服务配置
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Misty Isle
SMTP_SSL=false

# ============================================
# 前端地址（用于邮件链接）
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# Modal.com 视频处理配置
# ============================================
MODAL_ENDPOINT=https://your-modal-app.modal.run
MODAL_TOKEN=optional-auth-token
