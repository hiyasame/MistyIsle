# API Base URL
VITE_API_BASE_URL=https://api.yourdomain.com

# WebSocket URL
VITE_WS_BASE_URL=wss://api.yourdomain.com

# CDN Base URL (R2 公开访问地址)
VITE_CDN_BASE_URL=https://cdn.yourdomain.com

# SRS HTTP Base URL (用于播放 HTTP-FLV)
VITE_SRS_HTTP_BASE_URL=https://live.yourdomain.com

# SRS RTMP Base URL (用于推流)
VITE_SRS_RTMP_BASE_URL=rtmp://live.yourdomain.com:1935
